<div class="max-w-6xl mx-auto px-4 py-8 space-y-8">
  <!-- Profile Header Card -->
  <%= render "shared/components/card", padding: "8" do %>
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6 text-center md:text-left flex-col md:flex-row">
        <div class="h-24 w-24 rounded-3xl flex items-center justify-center text-indigo-600 bg-indigo-50 border border-indigo-100 text-3xl font-black shadow-inner">
          <%= @user.first_name[0] %><%= @user.last_name[0] rescue "" %>
        </div>
        <div>
          <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-1"><%= @user.full_name %></h1>
          <p class="text-slate-500 font-medium mb-3"><%= @user.email %></p>
          <div class="flex flex-wrap justify-center md:justify-start gap-2">
            <%= render "shared/components/badge", label: @user.role.titleize, color: :indigo, size: :md %>
            <% if @user.verified? %>
              <%= render "shared/components/badge", label: t("home.dashboard.verified"), color: :emerald, size: :md %>
            <% else %>
              <%= render "shared/components/badge", label: t("home.dashboard.unverified"), color: :amber, size: :md %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        <%= render "shared/components/button", label: t("home.dashboard.edit_profile"), path: identity_account_path, variant: :outline, class_name: "px-6" %>
        <%= render "shared/components/button", label: t("home.dashboard.sign_out"), path: sign_out_path, method: :delete, variant: :danger, class_name: "px-6" %>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Security Card -->
    <div class="lg:col-span-1">
      <%= render "shared/components/card", padding: "6", class_name: "h-full" do %>
        <h3 class="text-lg font-black text-slate-900 mb-6 flex items-center gap-3">
          <div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= t("home.dashboard.account_security") %>
        </h3>
        
        <div class="space-y-4">
          <div class="group p-4 bg-slate-50/50 rounded-2xl border border-slate-100 hover:border-indigo-100 transition-colors">
            <div class="flex items-center justify-between mb-1">
              <p class="text-sm font-black text-slate-800"><%= t("home.dashboard.two_factor_auth") %></p>
              <%= render "shared/components/badge", 
                         label: (@user.otp_required_for_login? ? t("home.dashboard.active") : t("home.dashboard.inactive")),
                         color: (@user.otp_required_for_login? ? :emerald : :slate),
                         size: :sm %>
            </div>
            <%= link_to t("home.dashboard.configure"), two_factor_settings_path, class: "text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 mt-2" %>
          </div>

          <div class="group p-4 bg-slate-50/50 rounded-2xl border border-slate-100 hover:border-indigo-100 transition-colors">
            <div class="flex items-center justify-between mb-1">
              <p class="text-sm font-black text-slate-800"><%= t("home.dashboard.password") %></p>
            </div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">
              <%= t("home.dashboard.last_changed") %>: <%= format_date(@user.updated_at) %>
            </p>
            <%= link_to t("home.dashboard.change"), edit_identity_password_path, class: "text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 mt-2" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Sessions Card -->
    <div class="lg:col-span-2">
      <%= render "shared/components/card", padding: "6", class_name: "h-full" do %>
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-black text-slate-900 flex items-center gap-3">
            <div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <%= t("home.dashboard.recent_sessions") %>
          </h3>
          <%= render "shared/components/button", label: t("home.dashboard.view_all"), path: sessions_path, variant: :outline, size: :sm, class_name: "text-[10px] px-3 py-1" %>
        </div>
        
        <div class="space-y-3">
          <% @sessions.each do |session| %>
            <div class="flex items-center justify-between p-4 bg-slate-50/50 rounded-2xl border border-slate-100 hover:bg-white transition-colors group">
              <div class="flex items-center gap-4">
                <div class="h-12 w-12 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 group-hover:text-indigo-500 transition-colors shadow-sm">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="flex items-center gap-2">
                    <p class="text-sm font-black text-slate-800"><%= session.user_agent.to_s.split.first.presence || "Unknown device" %></p>
                    <% if session == System::Current.session %>
                      <span class="px-1.5 py-0.5 rounded text-[8px] font-black uppercase bg-indigo-600 text-white"><%= t("home.dashboard.this_session") %></span>
                    <% end %>
                  </div>
                  <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-0.5">
                    IP: <%= session.ip_address.presence || "Unknown" %> • <%= time_ago_in_words(session.created_at) %> <%= t("common.ago") rescue "lalu" %>
                  </p>
                </div>
              </div>
              
              <% unless session == System::Current.session %>
                <%= button_to session_path(session), method: :delete, class: "p-2 text-slate-400 hover:text-rose-600 transition-colors", title: t("home.dashboard.logout") do %>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
