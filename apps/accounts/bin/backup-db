#!/usr/bin/env bash
# Exit on error
set -e

# Change directory to the setup folder where docker-compose resides
cd "$(dirname "$0")/../../../infra/compose"

# Load db name from environment or fallback to satu-raya.development
DB_NAME=$(docker compose exec -T db env | grep POSTGRES_DB | cut -d'=' -f2 | tr -d '\r\n')
DB_NAME=${DB_NAME:-satu-raya.development}

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_DIR="./backups/manual"
BACKUP_FILE="${BACKUP_DIR}/manual_${DB_NAME}_${TIMESTAMP}.sql.gz"

mkdir -p "${BACKUP_DIR}"

echo "Starting database backup for database '${DB_NAME}'..."
docker compose exec -T db pg_dump -U postgres -d "${DB_NAME}" | gzip > "${BACKUP_FILE}"
echo "Backup successfully saved to: ${BACKUP_FILE}"
