#!/usr/bin/env bash
set -e

BACKUP_FILE=$1

if [ -z "$BACKUP_FILE" ]; then
  echo "Error: No backup file specified."
  echo "Usage: ./bin/restore-db <path_to_backup_file>"
  echo ""
  echo "Available backups:"
  # Search inside the setup backups folder
  cd "$(dirname "$0")/../../../infra/compose"
  find backups -name "*.sql.gz" -o -name "*.sql" 2>/dev/null || echo "No backups found."
  exit 1
fi

if [ ! -f "$BACKUP_FILE" ]; then
  echo "Error: File '${BACKUP_FILE}' not found."
  exit 1
fi

# Resolve backup file path to absolute before changing directory
ABS_BACKUP_FILE=$(cd "$(dirname "$BACKUP_FILE")" && pwd)/$(basename "$BACKUP_FILE")

# Change directory to the setup folder where docker-compose resides
cd "$(dirname "$0")/../../../infra/compose"

# Load db name from container environment
DB_NAME=$(docker compose exec -T db env | grep POSTGRES_DB | cut -d'=' -f2 | tr -d '\r\n')
DB_NAME=${DB_NAME:-satu-raya.development}

echo "Preparing to restore database '${DB_NAME}' from '${ABS_BACKUP_FILE}'..."

# Confirm before proceeding
read -p "Warning: This will overwrite the existing database '${DB_NAME}'. Are you sure? (y/N) " -n 1 -r
echo ""
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  echo "Restore aborted."
  exit 0
fi

echo "Terminating existing database connections..."
docker compose exec -T db psql -U postgres -c "
SELECT pg_terminate_backend(pg_stat_activity.pid)
FROM pg_stat_activity
WHERE pg_stat_activity.datname = '${DB_NAME}'
  AND pid <> pg_backend_pid();" > /dev/null 2>&1 || true

echo "Recreating database '${DB_NAME}'..."
docker compose exec -T db psql -U postgres -c "DROP DATABASE IF EXISTS ${DB_NAME};"
docker compose exec -T db psql -U postgres -c "CREATE DATABASE ${DB_NAME};"

echo "Restoring database dump..."
if [[ "$ABS_BACKUP_FILE" == *.gz ]]; then
  gunzip -c "$ABS_BACKUP_FILE" | docker compose exec -T db psql -U postgres -d "${DB_NAME}"
else
  cat "$ABS_BACKUP_FILE" | docker compose exec -T db psql -U postgres -d "${DB_NAME}"
fi

echo "Database restore completed successfully!"
