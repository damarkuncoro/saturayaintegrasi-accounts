#!/bin/bash

# Pastikan script berhenti jika ada error
set -e

# Pindah ke root project (infra/compose)
cd "$(dirname "$0")/.."

# Fungsi cleanup
cleanup() {
  echo "🧹 Cleaning up test environment..."
  docker compose -f ../../infra/compose/docker-compose.test.yml down
}

# Jalankan cleanup saat script selesai (baik sukses maupun gagal)
trap cleanup EXIT

echo "🚀 Starting test dependencies (database, Redis)..."
docker compose -f ../../infra/compose/docker-compose.test.yml up -d db-test redis-test

echo "🧪 Running tests..."
docker compose -f ../../infra/compose/docker-compose.test.yml run --rm accounts-app-test /bin/bash -c "bundle exec rails db:migrate RAILS_ENV=test && bundle exec rails db:test:prepare && bundle exec rspec --tag ~type:system $@"
