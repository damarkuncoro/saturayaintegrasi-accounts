<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      /* Brand Branding Email Styles */
      body { font-family: 'Plus Jakarta Sans', Helvetica, Arial, sans-serif; background-color: #f8fafc; color: #1e293b; margin: 0; padding: 0; }
      .container { max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 16px; overflow: hidden; border: 1px solid #e2e8f0; }
      .header { padding: 32px; text-align: center; background: linear-gradient(to right, #7c3aed, var(--brand-primary, #4f46e5)); color: #ffffff; }
      .header h1 { margin: 0; font-size: 24px; font-weight: 800; letter-spacing: -0.025em; }
      .content { padding: 40px; line-height: 1.6; }
      .footer { padding: 24px; text-align: center; font-size: 12px; color: #94a3b8; border-top: 1px solid #f1f5f9; }
      .button { display: inline-block; padding: 12px 24px; background-color: var(--brand-primary, #4f46e5); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; margin-top: 24px; }
    </style>
  </head>

  <body style="--brand-primary: <%= brand_config.primary_color %>">
    <div class="container">
      <div class="header">
        <h1><%= brand_config.name %></h1>
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        &copy; <%= Time.current.year %> <%= brand_config.name %>. Seluruh hak cipta dilindungi undang-undang.
      </div>
    </div>
  </body>
</html>
