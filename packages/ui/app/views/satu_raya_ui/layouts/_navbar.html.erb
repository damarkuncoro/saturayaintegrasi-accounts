<header class="glass-header border-b border-slate-200/60 sticky top-0 z-50 backdrop-blur-md transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    
    <!-- Left Side: Brand Logo & Navigation -->
    <div class="flex items-center gap-8">
      <%= link_to root_path, class: "flex items-center gap-2 group shrink-0" do %>
        <span class="text-2xl font-black bg-gradient-to-r from-violet-600 via-indigo-600 to-indigo-500 bg-clip-text text-transparent tracking-tighter group-hover:scale-[1.02] transition-transform duration-200"><%= brand_config.name %></span>
        <% if System::Current.tenant %>
          <span class="inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-bold bg-slate-100 text-slate-600 border border-slate-200/80 truncate max-w-[120px] shadow-sm"><%= System::Current.tenant.name %></span>
        <% end %>
      <% end %>
      <%# Navigation links are managed by each application or brand slot %>
    </div>

    <!-- Right Side: Notifications & Profile Dropdown -->
    <div class="flex items-center gap-3">
      <% if System::Current.user %>
        <!-- Notifications (Standardized) -->
        <div class="relative">
           <button class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-full transition-all">
             <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
           </button>
        </div>

        <!-- Profile Menu Dropdown -->
        <div class="relative" data-controller="dropdown">
          <button type="button" 
                  data-action="click->dropdown#toggle"
                  class="flex items-center gap-2 p-1 rounded-full hover:bg-slate-100 transition-all focus:outline-none">
            <div class="h-9 w-9 rounded-full bg-gradient-to-tr from-violet-600 to-indigo-600 flex items-center justify-center text-white font-bold text-sm shadow-md ring-2 ring-white">
              <%= System::Current.user.first_name[0].upcase %>
            </div>
          </button>
          
          <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2.5 w-64 rounded-xl shadow-2xl bg-white border border-slate-100 divide-y divide-slate-100 z-50 transition-all">
            <div class="px-4 py-3">
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Masuk Sebagai</p>
              <p class="text-sm font-bold text-slate-800 truncate mt-0.5"><%= System::Current.user.full_name %></p>
              <p class="text-xs text-slate-500 truncate"><%= System::Current.user.email %></p>
            </div>
            <div class="py-1">
              <%= link_to "Pengaturan Akun", accounts_url_for("/settings"), class: "block px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50 hover:text-indigo-600 transition-colors" %>
              <%= link_to "Keamanan (2FA)", accounts_url_for("/two_factor_settings"), class: "block px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50 hover:text-indigo-600 transition-colors" %>
            </div>
            <div class="py-1">
              <%= button_to "Keluar", accounts_url_for("/logout"), method: :delete, class: "w-full text-left px-4 py-2.5 text-sm font-bold text-rose-600 hover:bg-rose-50 transition-colors" %>
            </div>
          </div>
        </div>
      <% else %>
        <%= link_to "Masuk", accounts_url_for("/login"), class: "text-sm font-bold text-slate-600 hover:text-indigo-600 transition-colors px-4 py-2" %>
        <%= link_to "Daftar", accounts_url_for("/register"), class: "text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 shadow-md shadow-indigo-200 px-5 py-2.5 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98]" %>
      <% end %>
    </div>
  </nav>
</header>
