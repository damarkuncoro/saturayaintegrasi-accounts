<% flash.each do |type, message| %>
  <div class="fixed top-20 right-4 z-[100] max-w-sm w-full animate-in fade-in slide-in-from-top-4 duration-300">
    <div role="alert" class="rounded-2xl shadow-2xl border p-4 flex items-start gap-3 backdrop-blur-md
      <%= type == 'notice' ? 'bg-emerald-50/90 border-emerald-100 text-emerald-800' : 'bg-rose-50/90 border-rose-100 text-rose-800' %>">
      <div class="shrink-0 mt-0.5">
        <% if type == 'notice' %>
          <svg class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <% else %>
          <svg class="h-5 w-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <% end %>
      </div>
      <div class="flex-1 text-sm font-semibold leading-relaxed">
        <%= message %>
      </div>
    </div>
  </div>
<% end %>
