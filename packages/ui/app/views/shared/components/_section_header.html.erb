<%
  wrapper_classes = [
    "mb-8",
    local_assigns[:class_name]
  ].compact.join(" ")
%>

<div class="<%= wrapper_classes %>">
  <% if local_assigns[:eyebrow].present? %>
    <p class="text-xs font-black uppercase tracking-[0.2em] text-indigo-600 mb-3"><%= local_assigns[:eyebrow] %></p>
  <% end %>

  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl"><%= local_assigns.fetch(:title) %></h1>
      <% if local_assigns[:subtitle].present? %>
        <p class="mt-3 max-w-2xl text-sm font-medium leading-6 text-slate-500"><%= local_assigns[:subtitle] %></p>
      <% end %>
    </div>

    <% if local_assigns[:action].present? %>
      <div class="flex shrink-0 items-center gap-3"><%= local_assigns[:action] %></div>
    <% end %>
  </div>
</div>
