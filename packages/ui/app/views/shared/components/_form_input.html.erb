<%
  form = local_assigns.fetch(:f)
  field = local_assigns.fetch(:field)
  type = local_assigns.fetch(:type, :text).to_sym
  input_classes = [
    "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-900 shadow-sm transition-colors",
    "placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-4 focus:ring-indigo-100",
    ("pl-11" if local_assigns[:prefix].present?),
    local_assigns[:class_name]
  ].compact.join(" ")
  options = {
    class: input_classes,
    placeholder: local_assigns[:placeholder],
    data: local_assigns.fetch(:data, {})
  }.compact
%>

<div class="relative">
  <% if local_assigns[:prefix].present? %>
    <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-sm font-black text-slate-400">
      <%= local_assigns[:prefix] %>
    </span>
  <% end %>

  <% if type == :area %>
    <%= form.text_area field, options.merge(rows: local_assigns.fetch(:rows, 4)) %>
  <% else %>
    <%= form.public_send("#{type}_field", field, options) %>
  <% end %>
</div>
