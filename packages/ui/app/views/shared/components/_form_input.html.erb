<%
  # Menangani arguments dengan default values yang aman
  form        = local_assigns[:f]
  field       = local_assigns[:field]
  type        = local_assigns[:type] || :text
  placeholder = local_assigns[:placeholder]
  prefix      = local_assigns[:prefix]
  rows        = local_assigns[:rows] || 4
  class_name  = local_assigns[:class_name]
  data        = local_assigns[:data] || {}

  form_input = ::SatuRayaUi::UI::Contract::FormInput.new(
    form: form,
    field: field,
    type: type,
    placeholder: placeholder,
    prefix: prefix,
    rows: rows,
    class_name: class_name,
    data: data,
    errors: local_assigns[:errors]
  )
  skin = ::SatuRayaUi::UI::Skins::FormInput.new(form_input)
%>

<div>
  <div <%= skin.render_attributes %> class="relative">
    <% if form_input.prefix.present? %>
      <span class="<%= skin.prefix_wrapper_classes %>">
        <%= form_input.prefix %>
      </span>
    <% end %>

    <% if form_input.type == :area %>
      <%= form_input.form.text_area form_input.field, skin.input_attributes.merge(rows: form_input.rows) %>
    <% else %>
      <%= form_input.form.public_send("#{form_input.type}_field", form_input.field, skin.input_attributes) %>
    <% end %>
  </div>

  <% if form_input.has_errors? %>
    <% form_input.error_messages.each do |message| %>
      <p class="<%= skin.error_classes %>"><%= message %></p>
    <% end %>
  <% end %>
</div>
