<%
  color_classes = {
    amber: "bg-amber-50 text-amber-700 ring-amber-200",
    blue: "bg-blue-50 text-blue-700 ring-blue-200",
    emerald: "bg-emerald-50 text-emerald-700 ring-emerald-200",
    indigo: "bg-indigo-50 text-indigo-700 ring-indigo-200",
    rose: "bg-rose-50 text-rose-700 ring-rose-200",
    slate: "bg-slate-50 text-slate-700 ring-slate-200"
  }
  size_classes = {
    sm: "px-2 py-0.5 text-[10px]",
    md: "px-2.5 py-1 text-xs"
  }
  badge_classes = [
    "inline-flex items-center rounded-full font-black uppercase tracking-wider ring-1 ring-inset",
    color_classes.fetch(local_assigns.fetch(:color, :slate).to_sym, color_classes[:slate]),
    size_classes.fetch(local_assigns.fetch(:size, :md).to_sym, size_classes[:md]),
    local_assigns[:class_name]
  ].compact.join(" ")
%>

<span class="<%= badge_classes %>"><%= local_assigns.fetch(:label) %></span>
