<%
  # Menangani arguments dengan default values yang aman
  label      = local_assigns[:label]
  color      = local_assigns[:color] || :slate
  size       = local_assigns[:size] || :md
  class_name = local_assigns[:class_name]

  badge = ::SatuRayaUi::UI::Contract::Badge.new(
    label: label,
    color: color,
    size: size,
    class_name: class_name
  )
  skin = ::SatuRayaUi::UI::Skins::Badge.new(badge)
%>

<span <%= skin.render_attributes %>><%= badge.label %></span>
