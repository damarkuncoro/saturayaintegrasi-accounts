<%
  # Menangani arguments dengan default values yang aman
  rounded   = local_assigns[:rounded] || "3xl"
  padding   = local_assigns[:padding] || "6"
  hover     = local_assigns[:hover] || false
  class_name = local_assigns[:class_name]

  card = ::SatuRayaUi::UI::Contract::Card.new(
    rounded: rounded,
    padding: padding,
    hover: hover,
    class_name: class_name
  )
  skin = ::SatuRayaUi::UI::Skins::Card.new(card)
%>

<div <%= skin.render_attributes %>>
  <%= yield %>
</div>
