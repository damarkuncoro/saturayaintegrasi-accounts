<%
  # Menangani arguments dengan default values yang aman
  current_page = local_assigns[:current_page]
  total_pages = local_assigns[:total_pages]
  total_count = local_assigns[:total_count]
  per_page = local_assigns[:per_page] || 20
  base_url = local_assigns[:base_url]

  pagination = ::SatuRayaUi::UI::Contract::Pagination.new(
    current_page: current_page,
    total_pages: total_pages,
    total_count: total_count,
    per_page: per_page,
    base_url: base_url
  )
  skin = ::SatuRayaUi::UI::Skins::Pagination.new(pagination)
%>

<div class="<%= skin.container_classes %>">
  <div class="flex flex-1 justify-between sm:hidden">
    <% if pagination.prev_page %>
      <%= link_to "Previous", skin.page_url(pagination.prev_page), class: skin.item_classes(nil) %>
    <% end %>
    <% if pagination.next_page %>
      <%= link_to "Next", skin.page_url(pagination.next_page), class: skin.item_classes(nil) %>
    <% end %>
  </div>
  <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
    <div>
      <p class="text-sm text-slate-700">
        Showing
        <span class="font-medium"><%= (pagination.current_page - 1) * pagination.per_page + 1 %></span>
        to
        <span class="font-medium"><%= [pagination.current_page * pagination.per_page, pagination.total_count].min %></span>
        of
        <span class="font-medium"><%= pagination.total_count %></span>
        results
      </p>
    </div>
    <div>
      <nav class="isolate inline-flex -space-x-px rounded-md" aria-label="Pagination">
        <% if pagination.prev_page %>
          <%= link_to skin.page_url(pagination.prev_page), class: skin.item_classes(nil), aria: { label: "Previous" } do %>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
            </svg>
          <% end %>
        <% end %>

        <% (1..pagination.total_pages).each do |page| %>
          <% if page == 1 || page == pagination.total_pages || (page - pagination.current_page).abs <= 2 %>
            <%= link_to page, skin.page_url(page), class: skin.item_classes(page), aria: { current: ("page" if page == pagination.current_page) } %>
          <% elsif (page - pagination.current_page).abs == 3 %>
            <span class="<%= skin.item_classes(nil) %>">...</span>
          <% end %>
        <% end %>

        <% if pagination.next_page %>
          <%= link_to skin.page_url(pagination.next_page), class: skin.item_classes(nil), aria: { label: "Next" } do %>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
          <% end %>
        <% end %>
      </nav>
    </div>
  </div>
</div>
