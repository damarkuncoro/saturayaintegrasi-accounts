<%
  form = local_assigns[:f] || local_assigns[:form]
  object = form&.object
%>

<% if object && object.errors.any? %>
  <div class="bg-rose-50 border-l-4 border-rose-500 p-4 mb-8 rounded-r-xl animate-in fade-in slide-in-from-top-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-rose-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-bold text-rose-800">
          <%= t("common.errors_occurred", count: object.errors.count) rescue "#{object.errors.count} kesalahan terjadi:" %>
        </h3>
        <div class="mt-2 text-sm text-rose-700">
          <ul class="list-disc pl-5 space-y-1">
            <% object.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
<% end %>
