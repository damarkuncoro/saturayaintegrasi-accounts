<%
  block_content = capture { yield } if block_given?
%>

<div class="rounded-3xl border-2 border-dashed border-slate-200 bg-white/70 px-6 py-14 text-center">
  <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-slate-300">
    <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V7a2 2 0 00-2-2h-3.5M4 13V7a2 2 0 012-2h3.5m0 0L12 3m-2.5 2L12 7m0-4l2.5 2M4 13l3 6h10l3-6M4 13h16" />
    </svg>
  </div>

  <h3 class="text-lg font-black text-slate-900"><%= local_assigns.fetch(:title) %></h3>
  <% if local_assigns[:description].present? %>
    <p class="mx-auto mt-2 max-w-md text-sm font-medium leading-6 text-slate-500"><%= local_assigns[:description] %></p>
  <% end %>

  <% if local_assigns[:action].present? || block_content.present? || content_for?(:action) %>
    <div class="mt-8 flex justify-center">
      <% if local_assigns[:action].present? %>
        <%= local_assigns[:action] %>
      <% elsif content_for?(:action) %>
        <%= content_for(:action) %>
      <% else %>
        <%= block_content %>
      <% end %>
    </div>
  <% end %>
</div>
