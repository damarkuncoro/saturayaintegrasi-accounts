<%
  # Menangani arguments dengan default values yang aman
  title = local_assigns[:title]
  id = local_assigns[:id]
  size = local_assigns[:size] || :md
  class_name = local_assigns[:class_name]

  modal = ::SatuRayaUi::UI::Contract::Modal.new(
    title: title,
    id: id,
    size: size,
    class_name: class_name
  )
  skin = ::SatuRayaUi::UI::Skins::Modal.new(modal)
%>

<div class="relative z-50" aria-labelledby="modal-title" role="dialog" aria-modal="true" id="<%= modal.id %>">
  <div class="<%= skin.backdrop_classes %>"></div>

  <div class="<%= skin.container_classes %>">
    <div class="<%= skin.content_classes %>">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <h3 class="text-lg font-bold text-slate-900" id="<%= modal.id %>-title">
          <%= modal.title %>
        </h3>
        <button type="button" class="text-slate-400 hover:text-slate-500 transition" data-action="click->modal#close">
          <span class="sr-only">Close</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="px-6 py-4">
        <%= yield %>
      </div>

      <% if content_for?(:modal_footer) %>
        <div class="px-6 py-4 bg-slate-50 rounded-b-2xl border-t border-slate-100 flex justify-end gap-3">
          <%= yield :modal_footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
