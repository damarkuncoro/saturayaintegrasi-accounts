<%
  # Menangani arguments dengan default values yang aman
  name       = local_assigns[:name]
  label      = local_assigns[:label]
  required   = local_assigns[:required] || false
  hint       = local_assigns[:hint]
  class_name = local_assigns[:class_name]

  form_field = ::SatuRayaUi::UI::Contract::FormField.new(
    name: name,
    label: label,
    required: required,
    hint: hint,
    class_name: class_name
  )
  skin = ::SatuRayaUi::UI::Skins::FormField.new(form_field)
%>

<div <%= skin.render_attributes %> class="<%= skin.wrapper_classes %>">
  <div class="flex items-center justify-between gap-3">
    <label for="<%= form_field.name %>" class="<%= skin.label_classes %>">
      <%= form_field.label %>
      <% if form_field.required %>
        <span class="text-rose-500">*</span>
      <% end %>
    </label>
  </div>

  <%= yield %>

  <% if form_field.hint.present? %>
    <p class="<%= skin.hint_classes %>"><%= form_field.hint %></p>
  <% end %>
</div>
