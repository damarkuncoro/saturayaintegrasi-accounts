<div class="max-w-2xl mx-auto px-4 py-12">
  <div class="flex items-center justify-between mb-12">
    <div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2"><%= t("passwords.edit.title") %></h1>
      <p class="text-slate-500 font-medium"><%= t("passwords.edit.description") %></p>
    </div>
    <%= link_to t("passwords.edit.back_button"), identity_dashboard_path, class: "text-sm font-bold text-slate-500 hover:text-indigo-600 transition-colors" %>
  </div>

  <%= render "shared/components/card", padding: "10" do %>
    <%= form_with(url: password_path, method: :patch, class: "space-y-8") do |form| %>
      
      <%= render "shared/components/form_field", label: t("passwords.edit.password_challenge_label"), name: :password_challenge, required: true do %>
        <%= render "shared/components/form_input", f: form, field: :password_challenge, type: :password, placeholder: "••••••••" %>
      <% end %>

      <%= render "shared/components/form_field", label: t("passwords.edit.password_label"), name: :password, required: true, hint: t("passwords.edit.password_hint") do %>
        <%= render "shared/components/form_input", f: form, field: :password, type: :password, placeholder: "••••••••••••" %>
      <% end %>

      <%= render "shared/components/form_field", label: t("passwords.edit.password_confirmation_label"), name: :password_confirmation, required: true do %>
        <%= render "shared/components/form_input", f: form, field: :password_confirmation, type: :password, placeholder: "••••••••••••" %>
      <% end %>

      <div class="pt-4">
        <%= render "shared/components/button", f: form, label: t("passwords.edit.submit"), variant: :primary, class_name: "w-full py-4 shadow-xl shadow-indigo-100" %>
      </div>
    <% end %>
  <% end %>
</div>
