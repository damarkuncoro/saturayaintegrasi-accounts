<%= render "shared/components/card", padding: "8 sm:10", rounded: "[2.5rem]" do %>
  <%= form_with(url: sign_in_path(return_to: params[:return_to]), class: "space-y-8") do |form| %>
    <%= render "shared/components/form_field", label: t("sessions.new.email"), name: :email do %>
      <%= render "shared/components/form_input", f: form, field: :email, type: :email, placeholder: "nama@email.com", data: { autofocus: true } %>
    <% end %>

    <%= render "shared/components/form_field", label: t("sessions.new.password"), name: :password do %>
      <%= render "shared/components/form_input", f: form, field: :password, type: :password, placeholder: "••••••••" %>
    <% end %>

    <div class="flex items-center justify-between">
      <%= render "shared/components/form_checkbox", f: form, field: :remember_me, label: t("sessions.new.remember_me") %>

      <div class="text-xs">
        <%= link_to t("sessions.new.forgot_password"), new_identity_password_reset_path, class: "font-black text-indigo-600 hover:text-indigo-500 transition-colors" %>
      </div>
    </div>

    <div>
      <%= render "shared/components/button", f: form, label: t("sessions.new.submit"), variant: :primary, class_name: "w-full py-4 shadow-xl shadow-indigo-100" %>
    </div>
  <% end %>

  <div class="mt-8">
    <div class="relative">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-slate-100"></div>
      </div>
      <div class="relative flex justify-center text-[10px] font-black uppercase tracking-widest">
        <span class="px-4 bg-white text-slate-400"><%= t("sessions.new.or_sign_in_with") %></span>
      </div>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-4">
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "w-full inline-flex justify-center py-3 px-4 border border-slate-200 rounded-xl bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition-all shadow-sm" do %>
        <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.92 3.4-2.12 4.48-1.2 1.08-2.76 1.84-4.72 1.84-4.24 0-7.72-3.48-7.72-7.72s3.48-7.72 7.72-7.72c2.16 0 3.88.76 5.16 2.04l2.44-2.44C18.64 2.24 15.84 1 12.48 1c-6.08 0-11 4.92-11 11s4.92 11 11 11c3.28 0 6.04-1.08 8.12-3 2.12-1.92 3.4-4.8 3.4-8.12 0-.68-.08-1.32-.24-1.96h-10.32z"/>
        </svg>
        Google
      <% end %>

      <%= button_to "/auth/github", method: :post, data: { turbo: false }, class: "w-full inline-flex justify-center py-3 px-4 border border-slate-200 rounded-xl bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition-all shadow-sm" do %>
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
        </svg>
        GitHub
      <% end %>
    </div>
  </div>
<% end %>
