<div class="max-w-6xl mx-auto px-4 py-12">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- Left Sidebar: Account Info & Actions -->
    <div class="lg:col-span-4 space-y-6">
      <%= render "shared/components/card", padding: "8" do %>
        <div class="text-center">
          <div class="h-24 w-24 bg-indigo-50 text-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-4 border border-indigo-100 shadow-inner">
            <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <h2 class="text-xl font-black text-slate-900"><%= @user.full_name %></h2>
          <p class="text-sm font-medium text-slate-500 mb-4"><%= @user.email %></p>
          
          <%= render "shared/components/badge", label: @user.role.titleize, color: :indigo, size: :md %>
        </div>

        <div class="mt-10 pt-8 border-t border-slate-100 space-y-2">
          <%= render "shared/components/button", label: t("accounts.show.change_password_link"), path: edit_identity_password_path, variant: :outline, class_name: "w-full justify-start" %>
          <%= render "shared/components/button", label: t("accounts.show.mfa_settings_link"), path: two_factor_settings_path, variant: :outline, class_name: "w-full justify-start" %>
        </div>
      <% end %>

      <!-- Quick Stats / Info -->
      <%= render "shared/components/card", padding: "6", class_name: "bg-slate-50/50" do %>
        <h3 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4"><%= t("accounts.show.account_details") %></h3>
        <dl class="space-y-4">
          <div>
            <dt class="text-[10px] font-black uppercase text-slate-400"><%= t("accounts.show.email_label") %></dt>
            <dd class="text-sm font-bold text-slate-700 truncate"><%= @user.email %></dd>
          </div>
          <div>
            <dt class="text-[10px] font-black uppercase text-slate-400">Created At</dt>
            <dd class="text-sm font-bold text-slate-700"><%= l @user.created_at, format: :long %></dd>
          </div>
        </dl>
      <% end %>
    </div>

    <!-- Main Content: Profile Form & Security -->
    <div class="lg:col-span-8 space-y-8">
      <%= render "shared/components/card", padding: "10" do %>
        <div class="mb-10">
          <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2"><%= t("accounts.show.title") %></h1>
          <p class="text-slate-500 font-medium"><%= t("accounts.show.description") %></p>
        </div>

        <!-- Profile Info -->
        <section>
          <h2 class="text-sm font-black uppercase tracking-[0.2em] text-indigo-500 mb-8 pb-2 border-b border-indigo-50 inline-block">
            <%= t("accounts.show.profile_section") %>
          </h2>
          
          <%= form_with model: @user, url: identity_account_path, method: :patch, class: "space-y-8" do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <%= render "shared/components/form_field", name: :first_name, label: t("registrations.new.first_name"), required: true do %>
                <%= render "shared/components/form_input", f: f, field: :first_name, placeholder: t("registrations.new.first_name_placeholder") %>
              <% end %>

              <%= render "shared/components/form_field", name: :last_name, label: t("registrations.new.last_name") do %>
                <%= render "shared/components/form_input", f: f, field: :last_name, placeholder: t("registrations.new.last_name_placeholder") %>
              <% end %>
            </div>

            <%= render "shared/components/form_field", name: :phone, label: t("registrations.new.phone"), hint: t("registrations.new.phone_hint") do %>
              <%= render "shared/components/form_input", f: f, field: :phone, type: :telephone, placeholder: "08..." %>
            <% end %>

            <div class="pt-4 flex justify-end">
              <%= render "shared/components/button", label: t("accounts.show.save_button"), path: "#", method: :submit, variant: :primary, class_name: "px-10 py-4 shadow-xl shadow-indigo-100" %>
            </div>
          <% end %>
        </section>
      <% end %>

      <!-- Danger Zone -->
      <%= render "shared/components/card", padding: "10", class_name: "border-rose-100 bg-rose-50/30" do %>
        <div class="flex items-start gap-6">
          <div class="h-12 w-12 bg-rose-100 text-rose-600 rounded-2xl flex items-center justify-center shrink-0">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-xl font-black text-rose-900 mb-2"><%= t("accounts.show.danger_zone") %></h2>
            <h3 class="text-rose-800 font-bold mb-1"><%= t("accounts.show.deactivate_title") %></h3>
            <p class="text-sm text-rose-700/80 leading-relaxed mb-8"><%= t("accounts.show.deactivate_desc") %></p>
            
            <%= form_with url: deactivate_identity_account_path, method: :post, class: "max-w-md space-y-6" do |f| %>
              <%= render "shared/components/form_field", name: :password_challenge, label: t("accounts.show.password_confirm_label"), required: true do %>
                <%= render "shared/components/form_input", f: f, field: :password_challenge, type: :password, class_name: "bg-white" %>
              <% end %>
              
              <%= render "shared/components/button", label: t("accounts.show.deactivate_button"), path: "#", method: :submit, variant: :danger, data: { confirm: t("accounts.show.confirm_deactivate") }, class_name: "w-full sm:w-auto" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
