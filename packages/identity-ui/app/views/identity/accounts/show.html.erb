<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <%= render "shared/components/section_header", 
      title: t("accounts.show.title"), 
      subtitle: t("accounts.show.description") %>

  <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
    
    <!-- Sidebar Navigation -->
    <aside class="lg:col-span-3 space-y-2 sticky top-24">
      <nav class="flex flex-col space-y-1">
        <a href="#profile" class="group flex items-center gap-3 px-4 py-3 text-sm font-bold text-indigo-600 bg-indigo-50 rounded-xl transition-all">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <%= t("accounts.show.sidebar.profile") %>
        </a>
        <a href="#security" class="group flex items-center gap-3 px-4 py-3 text-sm font-bold text-slate-500 hover:text-indigo-600 hover:bg-slate-50 rounded-xl transition-all">
          <svg class="h-5 w-5 text-slate-400 group-hover:text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <%= t("accounts.show.sidebar.security") %>
        </a>
        <a href="#advanced" class="group flex items-center gap-3 px-4 py-3 text-sm font-bold text-slate-500 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all">
          <svg class="h-5 w-5 text-slate-400 group-hover:text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          <%= t("accounts.show.sidebar.advanced") %>
        </a>
      </nav>

      <div class="pt-10 px-4">
        <div class="p-6 bg-gradient-to-br from-indigo-600 to-violet-700 rounded-[2rem] shadow-xl shadow-indigo-100 relative overflow-hidden group">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
          <div class="relative z-10">
             <div class="h-12 w-12 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center text-white mb-4">
               <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
             </div>
             <p class="text-xs font-bold text-indigo-100 uppercase tracking-widest mb-1">Status Akun</p>
             <p class="text-lg font-black text-white"><%= @user.role.titleize %></p>
             <div class="mt-4">
               <% if @user.verified? %>
                 <%= render "shared/components/badge", label: t("common.verified"), color: :green, size: :sm, class_name: "bg-white/20 text-white border-transparent" %>
               <% else %>
                 <%= render "shared/components/badge", label: t("common.not_verified"), color: :yellow, size: :sm, class_name: "bg-white/20 text-white border-transparent" %>
               <% end %>
             </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="lg:col-span-9 space-y-10">
      
      <!-- Section: Profile -->
      <section id="profile" class="scroll-mt-24">
        <%= render "shared/components/card", padding: "10", rounded: "[2.5rem]" do %>
          <div class="flex flex-col md:flex-row gap-10 items-start">
            <!-- Avatar Section -->
            <div class="flex-shrink-0 text-center space-y-4">
              <div class="relative group cursor-pointer">
                <div class="h-32 w-32 bg-slate-100 rounded-[2.5rem] flex items-center justify-center text-slate-400 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-all duration-300 ring-4 ring-white shadow-lg">
                  <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div class="absolute -bottom-2 -right-2 h-10 w-10 bg-white rounded-2xl shadow-lg border border-slate-100 flex items-center justify-center text-indigo-600 hover:scale-110 transition-transform">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
              </div>
              <div>
                <p class="text-xs font-black text-slate-400 uppercase tracking-widest"><%= t("accounts.show.account_details") %></p>
                <p class="text-sm font-bold text-slate-700 mt-1"><%= @user.email %></p>
              </div>
            </div>

            <!-- Form Section -->
            <div class="flex-1 w-full">
              <h3 class="text-xl font-black text-slate-900 mb-8"><%= t("accounts.show.profile_section") %></h3>
              <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-8" do |f| %>
                <%= render "shared/components/form_errors", f: f %>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <%= render "shared/components/form_field", name: :first_name, label: t("registrations.new.first_name"), required: true do %>
                    <%= render "shared/components/form_input", f: f, field: :first_name, placeholder: t("registrations.new.first_name_placeholder") %>
                  <% end %>

                  <%= render "shared/components/form_field", name: :last_name, label: t("registrations.new.last_name") do %>
                    <%= render "shared/components/form_input", f: f, field: :last_name, placeholder: t("registrations.new.last_name_placeholder") %>
                  <% end %>
                </div>

                <%= render "shared/components/form_field", name: :phone, label: t("registrations.new.phone"), hint: t("registrations.new.phone_hint") do %>
                  <%= render "shared/components/form_input", f: f, field: :phone, type: :telephone, placeholder: "08..." %>
                <% end %>

                <div class="pt-6 flex justify-end border-t border-slate-50">
                  <%= render "shared/components/button", f: f, label: t("accounts.show.save_button"), variant: :primary, class_name: "px-10 py-4 shadow-xl shadow-indigo-100" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>

      <!-- Section: Security -->
      <section id="security" class="scroll-mt-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%= render "shared/components/card", padding: "8", rounded: "[2.5rem]" do %>
            <div class="flex items-center gap-4 mb-6">
              <div class="h-12 w-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
              </div>
              <h3 class="text-lg font-black text-slate-900"><%= t("accounts.show.change_password_link") %></h3>
            </div>
            <p class="text-sm text-slate-500 font-medium mb-8 leading-relaxed">Ganti kata sandi Anda secara berkala untuk menjaga keamanan akun tetap optimal.</p>
            <%= render "shared/components/button", label: "Ganti Password", path: edit_password_path, variant: :outline, class_name: "w-full py-3.5" %>
          <% end %>

          <%= render "shared/components/card", padding: "8", rounded: "[2.5rem]" do %>
            <div class="flex items-center gap-4 mb-6">
              <div class="h-12 w-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A10.003 10.003 0 0012 20c4.083 0 7.774-2.147 9.412-5.335m-14.714-3.414l.011-.013M12 21V11.23a10.003 10.003 0 005.817-5.042L12 11.23a10.003 10.003 0 00-5.817-5.042L12 11.23z" /></svg>
              </div>
              <h3 class="text-lg font-black text-slate-900"><%= t("accounts.show.mfa_settings_link") %></h3>
            </div>
            <p class="text-sm text-slate-500 font-medium mb-8 leading-relaxed">Amankan akun Anda dengan lapisan keamanan tambahan menggunakan kode verifikasi.</p>
            <%= render "shared/components/button", label: "Kelola 2FA", path: two_factor_settings_path, variant: :outline, class_name: "w-full py-3.5" %>
          <% end %>
        </div>
      </section>

      <!-- Section: Advanced (Danger Zone) -->
      <section id="advanced" class="scroll-mt-24">
        <%= render "shared/components/card", padding: "10", rounded: "[2.5rem]", class_name: "border-rose-100 bg-rose-50/20" do %>
          <div class="flex flex-col md:flex-row gap-8">
            <div class="flex-1">
              <h3 class="text-xl font-black text-rose-900 mb-2"><%= t("accounts.show.danger_zone") %></h3>
              <p class="text-sm text-rose-700/80 font-medium leading-relaxed mb-6"><%= t("accounts.show.deactivate_desc") %></p>
              
              <%= form_with url: deactivate_account_path, method: :post, class: "max-w-md space-y-6" do |f| %>
                <%= render "shared/components/form_field", name: :password_challenge, label: t("accounts.show.password_confirm_label"), required: true do %>
                  <%= render "shared/components/form_input", f: f, field: :password_challenge, type: :password, class_name: "bg-white" %>
                <% end %>
                
                <%= render "shared/components/button", f: f, label: t("accounts.show.deactivate_button"), variant: :danger, data: { confirm: t("accounts.show.confirm_deactivate") }, class_name: "w-full sm:w-auto px-8 py-3.5" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>

    </div>
  </div>
</div>
