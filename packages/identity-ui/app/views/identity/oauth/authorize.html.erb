<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden">
  <%= render_brand_partial "identity/background" %>

  <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="flex justify-center">
      <% if brand_logo_url.present? %>
        <%= image_tag brand_logo_url, alt: brand_name, class: "h-16 w-auto" %>
      <% else %>
        <div class="h-16 w-16 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-xl shadow-indigo-200/50">
          <svg class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
      <% end %>
    </div>
    <h2 class="mt-8 text-center text-3xl font-black font-heading text-slate-900 tracking-tight">
      Persetujuan Akses
    </h2>
    <p class="mt-3 text-center text-sm text-slate-500 font-semibold">
      Aplikasi <strong><%= @client.client_name %></strong> meminta izin untuk mengakses akun Anda.
    </p>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-md relative z-10 px-4 sm:px-0">
    <%= render "shared/components/card", padding: "p-8 sm:p-10", rounded: "rounded-[2.5rem]" do %>
      <div class="space-y-6">
        <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
          <h3 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4">Izin yang diminta:</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="h-5 w-5 text-green-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm font-bold text-slate-700">Akses profil dasar (Nama)</span>
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-green-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm font-bold text-slate-700">Akses alamat email</span>
            </li>
          </ul>
        </div>

        <div class="flex flex-col space-y-3">
          <%= button_to oauth_consent_path(client_id: @client.client_id, allow: true), method: :post, class: "w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-lg shadow-indigo-200/50 text-sm font-black text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all cursor-pointer" do %>
            Izinkan Akses
          <% end %>

          <%= button_to oauth_consent_path(client_id: @client.client_id, allow: false), method: :post, class: "w-full flex justify-center py-3.5 px-4 border border-slate-200 rounded-xl bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition-all cursor-pointer" do %>
            Batalkan
          <% end %>
        </div>

        <p class="text-[10px] text-center text-slate-400 leading-relaxed">
          Dengan mengizinkan, Anda setuju untuk membagikan informasi akun Anda dengan <%= @client.client_name %>. 
          Anda dapat mencabut akses ini kapan saja melalui pengaturan akun <%= brand_name %>.
        </p>
      </div>
    <% end %>
  </div>
</div>
