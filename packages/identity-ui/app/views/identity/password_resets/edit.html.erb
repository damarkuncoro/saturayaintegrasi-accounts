<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden">
  <%= render_brand_partial "identity/background" %>

  <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="text-center mb-10">
      <div class="mx-auto h-16 w-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-200 mb-6">
        <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2"><%= t("password_resets.edit.title") %></h1>
      <p class="text-slate-500 font-medium px-4"><%= t("password_resets.edit.description") %></p>
    </div>

    <div class="px-4 sm:px-0">
      <%= render "shared/components/card", padding: "p-8 sm:p-10", rounded: "rounded-[2.5rem]" do %>
        <%= form_with(url: identity_password_reset_path(sid: params[:sid]), method: :patch, class: "space-y-8") do |form| %>
          
          <%= render "shared/components/form_field", label: t("password_resets.edit.password_label"), name: :password, required: true, hint: t("password_resets.edit.password_hint") do %>
            <%= render "shared/components/form_input", f: form, field: :password, type: :password, placeholder: "••••••••••••", autofocus: true, autocomplete: "new-password" %>
          <% end %>

          <%= render "shared/components/form_field", label: t("password_resets.edit.password_confirmation_label"), name: :password_confirmation, required: true do %>
            <%= render "shared/components/form_input", f: form, field: :password_confirmation, type: :password, placeholder: "••••••••••••", autocomplete: "new-password" %>
          <% end %>

          <div class="pt-4">
            <%= render "shared/components/button", f: form, label: t("password_resets.edit.submit"), variant: :primary, class_name: "w-full py-4 shadow-xl shadow-indigo-100" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
