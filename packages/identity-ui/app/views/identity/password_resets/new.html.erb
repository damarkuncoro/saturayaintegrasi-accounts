<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden">
  <%= render_brand_partial "identity/background" %>

  <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
    <div class="text-center mb-10">
      <div class="mx-auto h-16 w-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-200 mb-6">
        <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
        </svg>
      </div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2"><%= t("password_resets.new.title") %></h1>
      <p class="text-slate-500 font-medium px-4"><%= t("password_resets.new.description") %></p>
    </div>

    <div class="px-4 sm:px-0">
      <%= render "shared/components/card", padding: "8 sm:10", rounded: "[2.5rem]" do %>
        <%= form_with(url: identity_password_reset_path, class: "space-y-8") do |form| %>
          <%= render "shared/components/form_errors", f: form %>
          <%= render "shared/components/form_field", label: t("password_resets.new.email_label"), name: :email, required: true do %>
            <%= render "shared/components/form_input", f: form, field: :email, type: :email, placeholder: "nama@email.com", autofocus: true %>
          <% end %>

          <div class="pt-2">
            <%= render "shared/components/button", f: form, label: t("password_resets.new.submit"), variant: :primary, class_name: "w-full py-4 shadow-xl shadow-indigo-100" %>
          </div>
        <% end %>

        <div class="mt-8 pt-8 border-t border-slate-100 text-center">
          <%= link_to t("password_resets.new.back_to_login"), sign_in_path, class: "text-xs font-black text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-widest" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
