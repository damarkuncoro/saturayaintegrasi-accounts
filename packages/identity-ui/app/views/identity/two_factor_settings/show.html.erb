<div class="max-w-6xl mx-auto px-4 py-12">
  <%= render "shared/components/card", padding: "10" do %>
    <div class="flex items-center justify-between mb-12">
      <div class="flex items-center gap-6">
        <div class="h-16 w-16 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 border border-indigo-100 shadow-sm">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2"><%= t("two_factor_settings.show.title") %></h1>
          <p class="text-slate-500 font-medium"><%= t("two_factor_settings.show.description") %></p>
        </div>
      </div>
      <%= render "shared/components/button", label: t("two_factor_settings.show.back_button") rescue "Kembali", path: identity_dashboard_path, variant: :outline, size: :sm %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-7 space-y-10">
        <% if @backup_codes.present? %>
          <div class="p-8 bg-amber-50/50 border border-amber-100 rounded-[2rem] space-y-6 shadow-sm">
            <div class="flex items-center gap-4 text-amber-800">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <h3 class="font-black text-lg"><%= t("two_factor_settings.show.backup_codes_title") %></h3>
            </div>
            <p class="text-sm text-amber-700/80 font-medium leading-relaxed">
              <%= t("two_factor_settings.show.backup_codes_desc").html_safe %>
            </p>
            <div class="grid grid-cols-2 gap-4">
              <% @backup_codes.each do |code| %>
                <div class="bg-white px-4 py-3 rounded-xl border border-amber-100 text-center font-mono font-bold text-amber-900 shadow-sm select-all">
                  <%= code %>
                </div>
              <% end %>
            </div>
            <%= render "shared/components/button", label: t("two_factor_settings.show.print_pdf"), path: "javascript:window.print()", variant: :outline, class_name: "w-full bg-amber-100/50 border-amber-200 text-amber-800" %>
          </div>
        <% end %>

        <div class="space-y-8">
          <div class="flex items-center gap-3">
            <span class="text-xs font-black uppercase tracking-widest text-slate-400">Status</span>
            <% if @user.otp_required_for_login? %>
              <%= render "shared/components/badge", label: t("two_factor_settings.show.status_active"), color: :emerald, size: :md %>
            <% else %>
              <%= render "shared/components/badge", label: t("two_factor_settings.show.status_inactive"), color: :slate, size: :md %>
            <% end %>
          </div>

          <% if @user.otp_required_for_login? %>
            <div class="space-y-4">
              <h2 class="text-2xl font-black text-slate-900 tracking-tight"><%= t("two_factor_settings.show.account_secure_title") %></h2>
              <p class="text-slate-500 font-medium leading-relaxed">
                <%= t("two_factor_settings.show.account_secure_desc") %>
              </p>
            </div>

            <%= form_with url: disable_two_factor_settings_path, method: :post, class: "space-y-8 pt-4", data: { turbo: false } do |f| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <%= render "shared/components/form_field", name: :otp_code, label: t("two_factor_settings.show.otp_code_label"), required: true do %>
                  <%= render "shared/components/form_input", f: f, field: :otp_code, placeholder: "123456", data: { autocomplete: "one-time-code", inputmode: "numeric" } %>
                <% end %>

                <%= render "shared/components/form_field", name: :password_challenge, label: t("two_factor_settings.show.password_challenge_label"), required: true do %>
                  <%= render "shared/components/form_input", f: f, field: :password_challenge, type: :password %>
                <% end %>
              </div>
              <%= render "shared/components/button", f: f, label: t("two_factor_settings.show.disable_button"), variant: :danger, class_name: "px-10 py-4 shadow-xl shadow-rose-100" %>
            <% end %>
          <% else %>
            <div class="space-y-4">
              <h2 class="text-2xl font-black text-slate-900 tracking-tight"><%= t("two_factor_settings.show.activate_now_title") %></h2>
              <p class="text-slate-500 font-medium leading-relaxed">
                <%= t("two_factor_settings.show.activate_now_desc") %>
              </p>
            </div>

            <%= form_with url: enable_two_factor_settings_path, method: :post, class: "space-y-8 pt-4", data: { turbo: false } do |f| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <%= render "shared/components/form_field", name: :otp_code, label: t("two_factor_settings.show.otp_from_app_label"), required: true do %>
                  <%= render "shared/components/form_input", f: f, field: :otp_code, placeholder: "123456", data: { autocomplete: "one-time-code", inputmode: "numeric" } %>
                <% end %>

                <%= render "shared/components/form_field", name: :password_challenge, label: t("two_factor_settings.show.password_challenge_label"), required: true do %>
                  <%= render "shared/components/form_input", f: f, field: :password_challenge, type: :password %>
                <% end %>
              </div>
              <%= render "shared/components/button", f: f, label: t("two_factor_settings.show.enable_button"), variant: :primary, class_name: "px-10 py-4 shadow-xl shadow-indigo-100" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="lg:col-span-5 flex flex-col items-center justify-center">
        <% if @user.otp_secret.present? %>
          <div class="p-10 bg-white border border-slate-100 rounded-[3rem] shadow-2xl shadow-slate-200/50 relative group transition-transform hover:scale-[1.02]">
            <div class="absolute -top-4 -right-4 h-12 w-12 bg-indigo-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
              </svg>
            </div>
            <div class="<%= "opacity-30 grayscale" if @user.otp_required_for_login? %> transition-all">
              <%= @user.otp_qr_code.html_safe %>
            </div>
            <% if @user.otp_required_for_login? %>
              <div class="absolute inset-0 flex items-center justify-center p-8 text-center">
                <p class="text-xs font-black text-slate-400 uppercase tracking-widest leading-relaxed">
                  2FA sudah aktif.<br>QR Code dinonaktifkan untuk keamanan.
                </p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="w-full aspect-square max-w-[320px] p-12 bg-slate-50 border-4 border-dashed border-slate-200 rounded-[3rem] flex flex-col items-center justify-center text-center">
            <div class="h-20 w-20 bg-white rounded-3xl flex items-center justify-center text-slate-200 shadow-sm mb-8">
              <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
              </svg>
            </div>
            <p class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] leading-relaxed">
              <%= t("two_factor_settings.show.qr_placeholder").html_safe %>
            </p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
