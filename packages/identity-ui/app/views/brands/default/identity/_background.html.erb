<!-- Default Brand Background: Sophisticated Animated Orbs -->
<div class="absolute inset-0 overflow-hidden pointer-events-none select-none">
  <!-- Primary Orb -->
  <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-indigo-200/30 rounded-full blur-[120px] animate-pulse"></div>
  
  <!-- Secondary Orb -->
  <div class="absolute top-[20%] -right-[5%] w-[40%] h-[40%] bg-violet-200/20 rounded-full blur-[100px]"></div>
  
  <!-- Bottom Orb -->
  <div class="absolute -bottom-[15%] left-[20%] w-[60%] h-[50%] bg-blue-100/20 rounded-full blur-[130px]"></div>

  <!-- Subtle Grid Pattern (Optional, for texture) -->
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.03] mix-blend-overlay"></div>
</div>
